<UserControl x:Class="FanaBridge.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel>

            <!-- Connection Status -->
            <styles:SHSection Title="DEVICE STATUS" ShowSeparator="True">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Status: " FontWeight="Bold" VerticalAlignment="Center" Width="100" />
                        <TextBlock x:Name="txtStatus" Text="Checking..." VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Wheel: " FontWeight="Bold" VerticalAlignment="Center" Width="100" />
                        <TextBlock x:Name="txtWheelName" Text="—" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Capabilities: " FontWeight="Bold" VerticalAlignment="Center" Width="100" />
                        <TextBlock x:Name="txtCapabilities" Text="—" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                    <styles:SHButtonPrimary x:Name="btnReconnect" Click="BtnReconnect_Click" HorizontalAlignment="Left" Margin="0,8">
                        Reconnect
                    </styles:SHButtonPrimary>
                </StackPanel>
            </styles:SHSection>

            <!-- Active Profile -->
            <styles:SHSection Title="WHEEL PROFILE" ShowSeparator="True">
                <StackPanel>
                    <TextBlock x:Name="txtProfileHint" TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Connect a wheel to manage profiles." />
                    <StackPanel x:Name="panelProfilePicker" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Active: " FontWeight="Bold" VerticalAlignment="Center" Width="100" />
                            <ComboBox x:Name="cboProfile" Width="320" SelectionChanged="CboProfile_SelectionChanged" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Source: " FontWeight="Bold" VerticalAlignment="Center" Width="100" />
                            <TextBlock x:Name="txtProfileSource" Text="—" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <styles:SHButtonPrimary x:Name="btnDeleteProfile" Click="BtnDeleteProfile_Click"
                                                    IsEnabled="False" ToolTip="Delete the selected user profile from disk">
                                Delete Custom Profile
                            </styles:SHButtonPrimary>
                        </StackPanel>
                        <TextBlock x:Name="txtRestartNotice" Visibility="Collapsed"
                                   TextWrapping="Wrap" Margin="0,8,0,0"
                                   Foreground="#FFDDAA" FontStyle="Italic"
                                   Text="&#x26A0;  Profile changed. Restart SimHub for the device name to update in the Devices list. LED and display output uses the new profile immediately." />
                    </StackPanel>
                </StackPanel>
            </styles:SHSection>

            <!-- Quick Display Test -->
            <styles:SHSection Title="DISPLAY TEST" ShowSeparator="True">
                <StackPanel>
                    <TextBlock Text="Send a string to the 3-digit 7-segment display. Longer strings scroll automatically." Margin="0,0,0,6" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox x:Name="txtDisplayTest" Width="200" VerticalContentAlignment="Center" Margin="0,0,8,0" />
                        <styles:SHButtonPrimary x:Name="btnSendDisplay" Click="BtnSendDisplay_Click" Content="Send" VerticalAlignment="Center" />
                        <styles:SHButtonPrimary x:Name="btnStopScroll" Click="BtnStopScroll_Click" Margin="8,0,0,0" Visibility="Collapsed" Content="Stop" VerticalAlignment="Center" />
                        <styles:SHButtonPrimary x:Name="btnClearDisplay" Click="BtnClearDisplay_Click" Margin="8,0,0,0" Content="Clear" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Scroll speed (ms): " VerticalAlignment="Center" />
                        <TextBox x:Name="txtScrollSpeed" Width="50" Text="250" VerticalContentAlignment="Center" LostFocus="TxtScrollSpeed_LostFocus" />
                    </StackPanel>
                </StackPanel>
            </styles:SHSection>

            <!-- Wheel Profile Wizard -->
            <styles:SHSection Title="NEW WHEEL PROFILE" ShowSeparator="True">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Create a profile for an unsupported wheel. The wizard probes your hardware to detect LED and display capabilities, then saves a reusable JSON profile." />
                    <styles:SHButtonPrimary x:Name="btnCreateProfile" Click="BtnCreateProfile_Click" HorizontalAlignment="Left">
                        Launch Profile Wizard
                    </styles:SHButtonPrimary>
                </StackPanel>
            </styles:SHSection>

            <!-- Experimental Features -->
            <styles:SHSection Title="EXPERIMENTAL FEATURES" ShowSeparator="True">
                <StackPanel>
                    <CheckBox x:Name="chkEnableTuning"
                              Content="Enable tuning features (encoder mode, etc.)"
                              IsChecked="{Binding EnableTuning}"
                              Checked="ChkEnableTuning_Changed" Unchecked="ChkEnableTuning_Changed" />
                    <TextBlock Text="Tuning writes directly to device firmware settings via USB HID. Disabled by default."
                               TextWrapping="Wrap" Margin="20,4,0,0" Opacity="0.6" FontSize="11" />
                </StackPanel>
            </styles:SHSection>

            <!-- About -->
            <styles:SHSection Title="ABOUT" ShowSeparator="False">
                <StackPanel>
                    <TextBlock x:Name="txtPluginVersion" Text="FanaBridge" FontSize="14" FontWeight="SemiBold" Margin="0,2" />
                    <TextBlock x:Name="txtBuildInfo" Text="—" Foreground="#888" Margin="0,2" />
                    <TextBlock Margin="0,2">
                        <Hyperlink NavigateUri="https://github.com/kelchm/FanaBridge" RequestNavigate="RepoLink_RequestNavigate">
                            github.com/kelchm/FanaBridge
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </styles:SHSection>

        </StackPanel>
    </ScrollViewer>
</UserControl>
