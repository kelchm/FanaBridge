<UserControl x:Class="FanaBridge.UI.DisplayLayerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FanaBridge.UI"
             Margin="0,0,6,6" VerticalAlignment="Top" Width="90">
    <Border x:Name="cardBorder" Background="#252525" BorderBrush="#333" BorderThickness="2"
            CornerRadius="4" Padding="4,5" Cursor="Hand">
        <StackPanel HorizontalAlignment="Center">
            <!-- Top row: checkbox + priority badge -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,3">
                <CheckBox x:Name="chkEnabled" VerticalAlignment="Center" Margin="0,0,5,0"
                          Checked="ChkEnabled_Changed" Unchecked="ChkEnabled_Changed" />
                <Border x:Name="badgePriority" Background="#333" CornerRadius="2"
                        Width="16" Height="16" VerticalAlignment="Center">
                    <TextBlock x:Name="txtPriority" FontSize="9" FontWeight="Bold"
                               Foreground="#888" HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>

            <!-- Mini 7-seg preview -->
            <Border Background="#111" CornerRadius="3" Padding="3,2" Margin="0,0,0,3"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <local:SevenSegmentDigit x:Name="miniDigit0" Width="12" Height="18" Margin="0,0,1,0" />
                    <local:SevenSegmentDigit x:Name="miniDigit1" Width="12" Height="18" Margin="0,0,1,0" />
                    <local:SevenSegmentDigit x:Name="miniDigit2" Width="12" Height="18" />
                </StackPanel>
            </Border>

            <!-- Name -->
            <TextBlock x:Name="txtName" FontSize="10" Foreground="White"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Margin="0,0,0,3" />

            <!-- Mode pill -->
            <Border x:Name="pillMode" CornerRadius="3" Padding="4,1"
                    HorizontalAlignment="Center" Margin="0,0,0,1">
                <TextBlock x:Name="txtModePill" FontSize="7.5" FontWeight="SemiBold" />
            </Border>

            <!-- Timing pill (OnChange only) -->
            <Border x:Name="pillTiming" CornerRadius="3" Padding="4,1"
                    Background="#333" HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock x:Name="txtTimingPill" FontSize="7.5" Foreground="#AAA" />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
