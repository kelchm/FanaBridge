<UserControl x:Class="FanaBridge.UI.DisplayLayerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FanaBridge.UI"
             Margin="0,0,6,2" VerticalAlignment="Top" Width="120" Height="140">
    <Border x:Name="cardBorder" Background="#252525" BorderBrush="#333" BorderThickness="2"
            CornerRadius="4" Padding="6,6" Cursor="Hand">
        <Grid>
            <StackPanel>
                <!-- Header: name + priority -->
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="txtName" FontSize="11" FontWeight="SemiBold"
                               Foreground="White" TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" Margin="0,0,22,0" />
                    <Border x:Name="badgePriority" Background="#333" CornerRadius="2"
                            MinWidth="16" Height="16" Padding="3,0" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="txtPriority" FontSize="9" FontWeight="Bold"
                                   Foreground="#888" HorizontalAlignment="Center" TextAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>

                <!-- Mini 7-seg preview -->
                <Border Background="#111" CornerRadius="3" Padding="5,4" Margin="0,0,0,6"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <local:SevenSegmentDigit x:Name="miniDigit0" Width="22" Height="32" Margin="0,0,2,0" />
                        <local:SevenSegmentDigit x:Name="miniDigit1" Width="22" Height="32" Margin="0,0,2,0" />
                        <local:SevenSegmentDigit x:Name="miniDigit2" Width="22" Height="32" />
                    </StackPanel>
                </Border>

                <!-- Summary (property/source short name) -->
                <TextBlock x:Name="txtSummary" FontSize="9" Foreground="#888"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxWidth="106"
                           Margin="0,0,0,4" />

                <!-- Mode pill + scope tag -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border x:Name="pillMode" CornerRadius="3" Padding="4,1">
                        <TextBlock x:Name="txtModePill" FontSize="7.5" FontWeight="SemiBold" />
                    </Border>
                    <Border x:Name="pillScope" CornerRadius="3" Padding="4,1" Margin="3,0,0,0"
                            Background="#333" Visibility="Collapsed">
                        <TextBlock x:Name="txtScopePill" FontSize="7.5" FontWeight="SemiBold"
                                   Foreground="#999" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Status dot (bottom-left) -->
            <Ellipse x:Name="dotStatus" Width="8" Height="8"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="0,0,0,0"
                     ToolTip="Inactive" />
        </Grid>
    </Border>
</UserControl>
