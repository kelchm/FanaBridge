<UserControl x:Class="FanaBridge.UI.ScreenSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:local="clr-namespace:FanaBridge.UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <!-- ITM info banner -->
            <Border x:Name="borderItmInfo" Visibility="Collapsed"
                    Background="#1A4488CC" BorderBrush="#4488CC" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                <TextBlock Foreground="#AADDFF" FontSize="12" TextWrapping="Wrap">
                    &#x2139;  This wheel has an ITM display. FanaBridge currently supports basic display mode only — full ITM display support is planned.
                </TextBlock>
            </Border>

            <!-- Live combined preview (matches wheel output) -->
            <styles:SHSubSection Title="Live Display">
                <StackPanel>
                    <local:SevenSegmentPreview x:Name="previewDisplay" Margin="0,4,0,4" />
                    <TextBlock x:Name="txtActiveLayer" Foreground="#888" FontSize="11"
                               Margin="0,2,0,0" />
                </StackPanel>
            </styles:SHSubSection>

            <!-- Display Layers — unified split panel -->
            <styles:SHSubSection Title="Display Layers">
                <StackPanel>
                    <!-- Toolbar: add / remove / reorder -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <ComboBox x:Name="cmbAddLayer" Width="170" Margin="0,0,4,0"
                                  SelectionChanged="CmbAddLayer_SelectionChanged" />
                        <Button Content="Remove" Width="60" Margin="0,0,8,0"
                                Click="BtnRemove_Click" />
                        <Button Content="&#x25C0;" Width="28" Margin="0,0,2,0"
                                Click="BtnLeft_Click" ToolTip="Move left (higher priority)" />
                        <Button Content="&#x25B6;" Width="28"
                                Click="BtnRight_Click" ToolTip="Move right (lower priority)" />
                    </StackPanel>

                    <!-- Split panel container -->
                    <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <!-- Upper: layer card selector -->
                            <StackPanel Margin="8,6,8,0">
                                <!-- Priority direction hint -->
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Foreground="#666" FontSize="10" HorizontalAlignment="Left"
                                               Text="&#x25C0; Highest priority" />
                                    <TextBlock Foreground="#555" FontSize="10" HorizontalAlignment="Right"
                                               Text="Lowest priority &#x25B6;" />
                                </Grid>

                                <WrapPanel x:Name="layerStack" Orientation="Horizontal" />
                            </StackPanel>

                            <!-- Divider (dashed) -->
                            <Line X1="0" X2="1" Stretch="Fill" Margin="8,4,8,0"
                                  Stroke="#444" StrokeThickness="1"
                                  StrokeDashArray="4 3" SnapsToDevicePixels="True" />

                            <!-- Lower: settings for selected layer -->
                            <StackPanel x:Name="borderEditPanel" Visibility="Collapsed"
                                        Margin="10,8,10,10">
                                <TextBlock x:Name="txtEditHeader" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#CCC" Margin="0,0,0,8" />

                                <!-- Enabled -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Enabled" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <CheckBox x:Name="chkEnabled"
                                              Checked="ChkEnabled_Changed" Unchecked="ChkEnabled_Changed" />
                                </StackPanel>

                                <!-- Template (catalog layers) -->
                                <StackPanel x:Name="panelTemplate" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Template" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbTemplate" Width="200"
                                              SelectionChanged="CmbTemplate_SelectionChanged" />
                                </StackPanel>

                                <!-- Name (custom layers only) -->
                                <StackPanel x:Name="panelName" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Name" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="txtName" Width="200" TextChanged="TxtName_TextChanged"
                                             Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                                </StackPanel>

                                <!-- Show mode (custom layers only) -->
                                <StackPanel x:Name="panelTrigger" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Show" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbTrigger" Width="180"
                                              SelectionChanged="CmbTrigger_SelectionChanged">
                                        <ComboBoxItem Content="Always" Tag="Constant" />
                                        <ComboBoxItem Content="When value changes" Tag="OnChange" />
                                        <ComboBoxItem Content="While condition is true" Tag="WhileTrue" />
                                        <ComboBoxItem Content="Expression" Tag="Expression" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Watch property (OnChange/WhileTrue) -->
                                <StackPanel x:Name="panelWatch" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Watch" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="txtWatch" Width="260" TextChanged="TxtWatch_TextChanged"
                                             Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                                    <Button Content="Browse..." Margin="4,0,0,0" Click="BtnBrowseWatch_Click" />
                                </StackPanel>

                                <!-- Duration (OnChange only) -->
                                <StackPanel x:Name="panelDuration" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Duration" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbDuration" Width="80"
                                              SelectionChanged="CmbDuration_SelectionChanged">
                                        <ComboBoxItem Content="1.0s" Tag="1000" />
                                        <ComboBoxItem Content="1.5s" Tag="1500" />
                                        <ComboBoxItem Content="2.0s" Tag="2000" />
                                        <ComboBoxItem Content="3.0s" Tag="3000" />
                                        <ComboBoxItem Content="5.0s" Tag="5000" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Content source -->
                                <StackPanel x:Name="panelDisplaySource" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Content" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbDisplaySource" Width="140"
                                              SelectionChanged="CmbDisplaySource_SelectionChanged">
                                        <ComboBoxItem Content="Property value" Tag="Property" />
                                        <ComboBoxItem Content="Fixed text" Tag="FixedText" />
                                        <ComboBoxItem Content="Expression" Tag="Expression" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Property path (custom Property source) -->
                                <StackPanel x:Name="panelProperty" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Property" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="txtProperty" Width="260"
                                             TextChanged="TxtProperty_TextChanged"
                                             Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                                    <Button Content="Browse..." Margin="4,0,0,0"
                                            Click="BtnBrowseProperty_Click" />
                                </StackPanel>

                                <!-- Fixed text -->
                                <StackPanel x:Name="panelFixedText" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Text" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="txtFixedText" Width="200"
                                             TextChanged="TxtFixedText_TextChanged"
                                             Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                                </StackPanel>

                                <!-- Expression -->
                                <StackPanel x:Name="panelExpression" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Expression" Width="100" Foreground="#CCC"
                                                   VerticalAlignment="Center" />
                                        <TextBox x:Name="txtExpression" Width="360"
                                                 TextChanged="TxtExpression_TextChanged"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 MinHeight="50" MaxHeight="120"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Background="#2A2A2A" Foreground="White" BorderBrush="#444"
                                                 FontFamily="Consolas" FontSize="11" />
                                    </StackPanel>
                                    <TextBlock Foreground="#666" FontSize="10" Margin="100,0,0,6"
                                               Text="NCalc expression. Use [PropertyName] for properties." />
                                </StackPanel>

                                <!-- Format -->
                                <StackPanel x:Name="panelDisplayFormat" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Format" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbDisplayFormat" Width="140"
                                              SelectionChanged="CmbDisplayFormat_SelectionChanged">
                                        <ComboBoxItem Content="Number" Tag="Number" />
                                        <ComboBoxItem Content="Decimal" Tag="Decimal" />
                                        <ComboBoxItem Content="Time" Tag="Time" />
                                        <ComboBoxItem Content="Gear" Tag="Gear" />
                                        <ComboBoxItem Content="Text" Tag="Text" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Time format (Time only) -->
                                <StackPanel x:Name="panelTimeFormat" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Time format" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbTimeFormat" Width="140"
                                              SelectionChanged="CmbTimeFormat_SelectionChanged">
                                        <ComboBoxItem Content="ss.f" Tag="ss\.f" />
                                        <ComboBoxItem Content="m.ss" Tag="m\.ss" />
                                        <ComboBoxItem Content="m.ss.f" Tag="m\.ss\.f" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Scroll speed -->
                                <StackPanel x:Name="panelScrollSpeed" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Scroll speed" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbLayerScrollSpeed" Width="100"
                                              SelectionChanged="CmbLayerScrollSpeed_SelectionChanged">
                                        <ComboBoxItem Content="Fast" Tag="100" />
                                        <ComboBoxItem Content="Normal" Tag="250" />
                                        <ComboBoxItem Content="Slow" Tag="500" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Show when (Constant only) -->
                                <StackPanel x:Name="panelShowWhen" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Show when" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <CheckBox x:Name="chkRunning" Content="In session" Margin="0,0,12,0"
                                              Foreground="#CCC"
                                              Checked="ChkRunning_Changed" Unchecked="ChkRunning_Changed" />
                                    <CheckBox x:Name="chkIdle" Content="Idle" Foreground="#CCC"
                                              Checked="ChkIdle_Changed" Unchecked="ChkIdle_Changed" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </styles:SHSubSection>


        </StackPanel>
    </ScrollViewer>
</UserControl>
