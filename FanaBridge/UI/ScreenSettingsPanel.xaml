<UserControl x:Class="FanaBridge.UI.ScreenSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:local="clr-namespace:FanaBridge.UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <!-- ITM info banner -->
            <Border x:Name="borderItmInfo" Visibility="Collapsed"
                    Background="#1A4488CC" BorderBrush="#4488CC" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                <TextBlock Foreground="#AADDFF" FontSize="12" TextWrapping="Wrap">
                    &#x2139;  This wheel has an ITM display. FanaBridge currently supports basic display mode only — full ITM display support is planned.
                </TextBlock>
            </Border>

            <!-- Live combined preview (matches wheel output) -->
            <styles:SHSubSection Title="Live Display">
                <StackPanel>
                    <local:SevenSegmentPreview x:Name="previewDisplay" Margin="0,4,0,4" />
                    <TextBlock x:Name="txtActiveLayer" Foreground="#888" FontSize="11"
                               Margin="0,2,0,0" />
                </StackPanel>
            </styles:SHSubSection>

            <!-- Unified layer stack -->
            <styles:SHSubSection Title="Display Layers">
                <StackPanel>
                    <!-- Priority direction hint -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Foreground="#666" FontSize="10" HorizontalAlignment="Left"
                                   Text="&#x25C0; Higher priority" />
                        <TextBlock Foreground="#555" FontSize="10" HorizontalAlignment="Right"
                                   Text="Lower priority &#x25B6;" />
                    </Grid>

                    <!-- Layer cards (horizontal wrap) -->
                    <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                            CornerRadius="4" Padding="6" MinHeight="40">
                        <WrapPanel x:Name="layerStack" Orientation="Horizontal" />
                    </Border>

                    <!-- Toolbar -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <ComboBox x:Name="cmbAddLayer" Width="170" Margin="0,0,4,0"
                                  SelectionChanged="CmbAddLayer_SelectionChanged" />
                        <Button Content="Remove" Width="60" Margin="0,0,4,0"
                                Click="BtnRemove_Click" />
                        <Button Content="&#x25C0;" Width="28" Margin="0,0,2,0"
                                Click="BtnLeft_Click" ToolTip="Move left (higher priority)" />
                        <Button Content="&#x25B6;" Width="28"
                                Click="BtnRight_Click" ToolTip="Move right (lower priority)" />
                    </StackPanel>
                </StackPanel>
            </styles:SHSubSection>

            <!-- Edit panel for selected layer -->
            <styles:SHSubSection x:Name="sectionEdit" Title="Layer Settings" Visibility="Collapsed">
                <StackPanel>
                    <!-- Data source (Constant layers with catalog key) -->
                    <StackPanel x:Name="panelDataSource" Orientation="Horizontal"
                                Margin="0,0,0,6" Visibility="Collapsed">
                        <TextBlock Text="Data Source" Width="100" Foreground="#CCC"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="cmbDataSource" Width="200"
                                  SelectionChanged="CmbDataSource_SelectionChanged" />
                    </StackPanel>

                    <!-- Name (custom layers only) -->
                    <StackPanel x:Name="panelName" Orientation="Horizontal"
                                Margin="0,0,0,6" Visibility="Collapsed">
                        <TextBlock Text="Name" Width="100" Foreground="#CCC"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="txtName" Width="200" TextChanged="TxtName_TextChanged"
                                 Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                    </StackPanel>

                    <!-- Trigger type (custom layers only) -->
                    <StackPanel x:Name="panelTrigger" Orientation="Horizontal"
                                Margin="0,0,0,6" Visibility="Collapsed">
                        <TextBlock Text="Trigger" Width="100" Foreground="#CCC"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="cmbTrigger" Width="140"
                                  SelectionChanged="CmbTrigger_SelectionChanged">
                            <ComboBoxItem Content="Constant" Tag="Constant" />
                            <ComboBoxItem Content="On change" Tag="OnChange" />
                            <ComboBoxItem Content="While true" Tag="WhileTrue" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Watch property (OnChange/WhileTrue) -->
                    <StackPanel x:Name="panelWatch" Orientation="Horizontal"
                                Margin="0,0,0,6" Visibility="Collapsed">
                        <TextBlock Text="Watch" Width="100" Foreground="#CCC"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="txtWatch" Width="260" TextChanged="TxtWatch_TextChanged"
                                 Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                        <Button Content="Browse..." Margin="4,0,0,0" Click="BtnBrowseWatch_Click" />
                    </StackPanel>

                    <!-- Duration (OnChange only) -->
                    <StackPanel x:Name="panelDuration" Orientation="Horizontal"
                                Margin="0,0,0,6" Visibility="Collapsed">
                        <TextBlock Text="Duration" Width="100" Foreground="#CCC"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="cmbDuration" Width="80"
                                  SelectionChanged="CmbDuration_SelectionChanged">
                            <ComboBoxItem Content="1.0s" Tag="1000" />
                            <ComboBoxItem Content="1.5s" Tag="1500" />
                            <ComboBoxItem Content="2.0s" Tag="2000" />
                            <ComboBoxItem Content="3.0s" Tag="3000" />
                            <ComboBoxItem Content="5.0s" Tag="5000" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Display source -->
                    <StackPanel x:Name="panelDisplaySource" Orientation="Horizontal"
                                Margin="0,0,0,6" Visibility="Collapsed">
                        <TextBlock Text="Display" Width="100" Foreground="#CCC"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="cmbDisplaySource" Width="140"
                                  SelectionChanged="CmbDisplaySource_SelectionChanged">
                            <ComboBoxItem Content="Property value" Tag="Property" />
                            <ComboBoxItem Content="Fixed text" Tag="FixedText" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Property path (custom Property source) -->
                    <StackPanel x:Name="panelProperty" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Property" Width="100" Foreground="#CCC"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="txtProperty" Width="260"
                                     TextChanged="TxtProperty_TextChanged"
                                     Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                            <Button Content="Browse..." Margin="4,0,0,0"
                                    Click="BtnBrowseProperty_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Format" Width="100" Foreground="#CCC"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="txtFormat" Width="140"
                                     TextChanged="TxtFormat_TextChanged"
                                     Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Fixed text -->
                    <StackPanel x:Name="panelFixedText" Orientation="Horizontal"
                                Margin="0,0,0,6" Visibility="Collapsed">
                        <TextBlock Text="Text" Width="100" Foreground="#CCC"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="txtFixedText" Width="200"
                                 TextChanged="TxtFixedText_TextChanged"
                                 Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                    </StackPanel>

                    <!-- Show when (Constant only) -->
                    <StackPanel x:Name="panelShowWhen" Orientation="Horizontal"
                                Margin="0,0,0,6" Visibility="Collapsed">
                        <TextBlock Text="Show when" Width="100" Foreground="#CCC"
                                   VerticalAlignment="Center" />
                        <CheckBox x:Name="chkRunning" Content="In session" Margin="0,0,12,0"
                                  Foreground="#CCC"
                                  Checked="ChkRunning_Changed" Unchecked="ChkRunning_Changed" />
                        <CheckBox x:Name="chkIdle" Content="Idle" Foreground="#CCC"
                                  Checked="ChkIdle_Changed" Unchecked="ChkIdle_Changed" />
                    </StackPanel>
                </StackPanel>
            </styles:SHSubSection>

            <!-- Display Options -->
            <styles:SHSubSection Title="Display Options">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Scroll speed:" Foreground="#999" VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <ComboBox x:Name="cmbScrollSpeed" Width="80"
                              SelectionChanged="CmbScrollSpeed_SelectionChanged">
                        <ComboBoxItem Content="Fast" Tag="100" />
                        <ComboBoxItem Content="Normal" Tag="250" IsSelected="True" />
                        <ComboBoxItem Content="Slow" Tag="500" />
                    </ComboBox>
                </StackPanel>
            </styles:SHSubSection>

        </StackPanel>
    </ScrollViewer>
</UserControl>
