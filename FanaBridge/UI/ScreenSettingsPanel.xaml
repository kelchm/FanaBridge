<UserControl x:Class="FanaBridge.UI.ScreenSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:local="clr-namespace:FanaBridge.UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <!-- ITM info banner -->
            <Border x:Name="borderItmInfo" Visibility="Collapsed"
                    Background="#1A4488CC" BorderBrush="#4488CC" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                <TextBlock Foreground="#AADDFF" FontSize="12" TextWrapping="Wrap">
                    &#x2139;  This wheel has an ITM display. FanaBridge currently supports basic display mode only — full ITM display support is planned.
                </TextBlock>
            </Border>

            <!-- Live combined preview -->
            <styles:SHSubSection Title="Live Display">
                <StackPanel>
                    <local:SevenSegmentPreview x:Name="previewDisplay" Margin="0,4,0,4" />
                    <TextBlock x:Name="txtActiveLayer" Foreground="#888" FontSize="11"
                               Margin="0,2,0,0" />
                </StackPanel>
            </styles:SHSubSection>

            <!-- Display Layers -->
            <styles:SHSubSection Title="Display Layers">
                <StackPanel>
                    <!-- Toolbar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <ComboBox x:Name="cmbAddLayer" Width="170" Margin="0,0,4,0"
                                  SelectionChanged="CmbAddLayer_SelectionChanged" />
                        <Button Content="Remove" Width="60" Margin="0,0,8,0"
                                Click="BtnRemove_Click" />
                        <Button Content="&#x25C0;" Width="28" Margin="0,0,2,0"
                                Click="BtnLeft_Click" ToolTip="Move left (higher priority)" />
                        <Button Content="&#x25B6;" Width="28"
                                Click="BtnRight_Click" ToolTip="Move right (lower priority)" />
                    </StackPanel>

                    <!-- Layer cards -->
                    <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <StackPanel Margin="8,6,8,0">
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Foreground="#666" FontSize="10" HorizontalAlignment="Left"
                                               Text="&#x25C0; Highest priority" />
                                    <TextBlock Foreground="#555" FontSize="10" HorizontalAlignment="Right"
                                               Text="Lowest priority &#x25B6;" />
                                </Grid>
                                <WrapPanel x:Name="layerStack" Orientation="Horizontal" />
                            </StackPanel>

                            <!-- Divider -->
                            <Line X1="0" X2="1" Stretch="Fill" Margin="8,4,8,0"
                                  Stroke="#444" StrokeThickness="1"
                                  StrokeDashArray="4 3" SnapsToDevicePixels="True" />

                            <!-- Edit panel for selected layer -->
                            <StackPanel x:Name="borderEditPanel" Visibility="Collapsed"
                                        Margin="10,8,10,10">
                                <TextBlock x:Name="txtEditHeader" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#CCC" Margin="0,0,0,8" />

                                <!-- Enabled -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Enabled" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <CheckBox x:Name="chkRunning" Content="In Game" Margin="0,0,12,0"
                                              Foreground="#CCC"
                                              Checked="ChkRunning_Changed" Unchecked="ChkRunning_Changed" />
                                    <CheckBox x:Name="chkIdle" Content="Idle" Foreground="#CCC"
                                              Checked="ChkIdle_Changed" Unchecked="ChkIdle_Changed" />
                                </StackPanel>

                                <!-- Template (catalog layers) -->
                                <StackPanel x:Name="panelTemplate" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Template" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbTemplate" Width="200"
                                              SelectionChanged="CmbTemplate_SelectionChanged" />
                                </StackPanel>

                                <!-- Name (custom layers) -->
                                <StackPanel x:Name="panelName" Orientation="Horizontal"
                                            Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Name" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="txtLayerName" Width="200"
                                             TextChanged="TxtLayerName_TextChanged"
                                             Background="#2A2A2A" Foreground="White" BorderBrush="#444" />
                                </StackPanel>

                                <!-- Effect (all layers) -->
                                <StackPanel x:Name="panelEffect" Orientation="Horizontal"
                                            Margin="0,0,0,6">
                                    <TextBlock Text="Effect" Width="100" Foreground="#CCC"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmbEffect" Width="140"
                                              SelectionChanged="CmbEffect_SelectionChanged">
                                        <ComboBoxItem Content="None" Tag="None" />
                                        <ComboBoxItem Content="Blink" Tag="Blink" />
                                        <ComboBoxItem Content="Flash" Tag="Flash" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </styles:SHSubSection>

        </StackPanel>
    </ScrollViewer>
</UserControl>
