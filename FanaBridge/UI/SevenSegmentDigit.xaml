<UserControl x:Class="FanaBridge.UI.SevenSegmentDigit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        7-segment digit using a Viewbox for resolution-independent scaling.
        Design size: 38x58. Scales to fit whatever Width/Height is set on the control.

        Segment bit mapping (matches SevenSegment.cs encoding):
          bit 0 = a (top),     bit 1 = b (upper-right), bit 2 = c (lower-right),
          bit 3 = d (bottom),  bit 4 = e (lower-left),  bit 5 = f (upper-left),
          bit 6 = g (middle),  bit 7 = dp (decimal point)
    -->
    <Viewbox Stretch="Uniform">
        <Canvas Width="38" Height="58">
            <!-- a: top horizontal -->
            <Rectangle x:Name="segA" Width="22" Height="4" Canvas.Left="6" Canvas.Top="2"
                       RadiusX="1.5" RadiusY="1.5" />
            <!-- b: upper-right vertical -->
            <Rectangle x:Name="segB" Width="4" Height="20" Canvas.Left="28" Canvas.Top="5"
                       RadiusX="1.5" RadiusY="1.5" />
            <!-- c: lower-right vertical -->
            <Rectangle x:Name="segC" Width="4" Height="20" Canvas.Left="28" Canvas.Top="31"
                       RadiusX="1.5" RadiusY="1.5" />
            <!-- d: bottom horizontal -->
            <Rectangle x:Name="segD" Width="22" Height="4" Canvas.Left="6" Canvas.Top="51"
                       RadiusX="1.5" RadiusY="1.5" />
            <!-- e: lower-left vertical -->
            <Rectangle x:Name="segE" Width="4" Height="20" Canvas.Left="2" Canvas.Top="31"
                       RadiusX="1.5" RadiusY="1.5" />
            <!-- f: upper-left vertical -->
            <Rectangle x:Name="segF" Width="4" Height="20" Canvas.Left="2" Canvas.Top="5"
                       RadiusX="1.5" RadiusY="1.5" />
            <!-- g: middle horizontal -->
            <Rectangle x:Name="segG" Width="22" Height="4" Canvas.Left="6" Canvas.Top="27"
                       RadiusX="1.5" RadiusY="1.5" />
            <!-- dp: decimal point -->
            <Ellipse x:Name="segDP" Width="4" Height="4" Canvas.Left="34" Canvas.Top="51" />
        </Canvas>
    </Viewbox>
</UserControl>
