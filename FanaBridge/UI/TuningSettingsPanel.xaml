<UserControl x:Class="FanaBridge.UI.TuningSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">

            <Border Background="#332200" BorderBrush="#886600" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <TextBlock Text="&#x26A0;  Tuning features are experimental. They write directly to device firmware settings via USB HID. Use at your own risk."
                           TextWrapping="Wrap" Foreground="#FFDDAA" />
            </Border>

            <!-- Shown when tuning is disabled -->
            <StackPanel x:Name="panelDisabled" Visibility="Visible">
                <TextBlock Text="Tuning features are disabled. Enable them in the FanaBridge plugin settings under Experimental Features."
                           TextWrapping="Wrap" Opacity="0.6" />
            </StackPanel>

            <!-- Shown when tuning is enabled -->
            <StackPanel x:Name="panelEnabled" Visibility="Collapsed">

                <styles:SHButtonPrimary x:Name="btnRefresh" Click="BtnRefresh_Click"
                                        HorizontalAlignment="Left" Margin="0,0,0,12"
                                        Content="Refresh from device" />

                <styles:SHSubSection Title="Encoder Mode">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Changes encoder behavior on the button module. Reads current tuning state and modifies only the encoder mode."
                                   TextWrapping="Wrap" Margin="0,0,0,6" Opacity="0.7" />
                        <ComboBox x:Name="cmbEncoderMode"
                                  SelectionChanged="CmbEncoderMode_SelectionChanged"
                                  Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Encoder (Relative)" Tag="Encoder" />
                            <ComboBoxItem Content="Pulse (Absolute)" Tag="Pulse" />
                            <ComboBoxItem Content="Constant (Absolute)" Tag="Constant" />
                            <ComboBoxItem Content="Auto" Tag="Auto" />
                        </ComboBox>
                    </StackPanel>
                </styles:SHSubSection>

                <Expander Header="Debug: Raw Tuning Dump" IsExpanded="False" Margin="0,12,0,0">
                    <TextBox x:Name="txtTuningDump" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="11"
                             TextWrapping="Wrap" Margin="0,6,0,0"
                             Background="Transparent" BorderThickness="0"
                             Text="Press 'Refresh from device' to read." />
                </Expander>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
