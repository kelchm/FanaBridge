<Window x:Class="FanaBridge.WheelProfileWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FanaBridge — New Wheel Profile"
        Width="560" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF252525"
        Foreground="White">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Width" Value="80"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="txtStepTitle" FontSize="18" FontWeight="Bold" />
            <TextBlock x:Name="txtStepSubtitle" FontSize="12" Foreground="#AAAAAA"
                       Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- ── Step content ────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- Step 0: Welcome -->
            <StackPanel x:Name="stepWelcome" Visibility="Visible">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                    This wizard probes your wheel's hardware to discover its LEDs
                    and display.  Make sure you can see the wheel — the wizard will
                    send test signals and ask what you observe.
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="Wheel type:" FontWeight="Bold" Width="100" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtWizWheelType" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Module:" FontWeight="Bold" Width="100" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtWizModuleType" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,20,0,4">
                    <TextBlock Text="Profile name:" FontWeight="Bold" Width="100" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtProfileName" Width="300" />
                </StackPanel>
            </StackPanel>

            <!-- Step 1: Display probe -->
            <StackPanel x:Name="stepDisplay" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,20">
                    A test pattern ("888") has been sent to the display.
                    Look at your wheel — what do you see?
                </TextBlock>
                <StackPanel HorizontalAlignment="Center">
                    <Button Content="&#x2714;  I can see 888 on the display"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="DisplayYes_Click"/>
                    <Button Content="&#x2753;  I have a display, but nothing appeared"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="DisplayNotWorking_Click"/>
                    <Button Content="&#x2716;  My wheel has no display"
                            HorizontalAlignment="Stretch" Click="DisplayNo_Click"/>
                </StackPanel>
                <TextBlock x:Name="txtDisplayResult" HorizontalAlignment="Center"
                           Margin="0,16,0,0" FontWeight="Bold" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 2: Rev LED probe -->
            <StackPanel x:Name="stepRevLeds" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16">
                    Bright RED has been sent to the RPM / shift-indicator LED slots.
                    These are usually in a horizontal row across the top of the wheel.
                </TextBlock>
                <StackPanel HorizontalAlignment="Center">
                    <Button Content="&#x2714;  I see red LEDs — let me count them"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="RevSome_Click"/>
                    <Button Content="&#x2753;  Nothing lit up (but my wheel has rev LEDs)"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="RevNotWorking_Click"/>
                    <Button Content="&#x2716;  My wheel has no rev / RPM LEDs"
                            HorizontalAlignment="Stretch" Click="RevNone_Click"/>
                </StackPanel>
                <StackPanel x:Name="panelRevCount" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock Text="How many lit up?" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cboRevCount" SelectedIndex="0">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="8"/>
                        <ComboBoxItem Content="9"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock x:Name="txtRevResult" HorizontalAlignment="Center"
                           Margin="0,12,0,0" FontWeight="Bold" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 3: Flag LED probe -->
            <StackPanel x:Name="stepFlagLeds" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16">
                    All previous LEDs have been turned off.
                    BLUE has been sent to the flag / status LED slots.
                    Do you see any NEW LEDs?  (Do not count the RPM row.)
                </TextBlock>
                <StackPanel HorizontalAlignment="Center">
                    <Button Content="&#x2714;  I see blue LEDs — let me count them"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="FlagSome_Click"/>
                    <Button Content="&#x2753;  Nothing lit up (but my wheel has flag LEDs)"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="FlagNotWorking_Click"/>
                    <Button Content="&#x2716;  My wheel has no flag / status LEDs"
                            HorizontalAlignment="Stretch" Click="FlagNone_Click"/>
                </StackPanel>
                <StackPanel x:Name="panelFlagCount" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock Text="Total count (both sides):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cboFlagCount" SelectedIndex="0">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock x:Name="txtFlagResult" HorizontalAlignment="Center"
                           Margin="0,12,0,0" FontWeight="Bold" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 4: Button Color LED probe -->
            <StackPanel x:Name="stepColorLeds" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16">
                    All previous LEDs have been turned off.
                    Bright GREEN has been sent to all button / color LED slots.
                    These are typically behind buttons or around encoder knobs.
                </TextBlock>
                <StackPanel HorizontalAlignment="Center">
                    <Button Content="&#x2714;  I see green LEDs — let me count them"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="ColorSome_Click"/>
                    <Button Content="&#x2753;  Nothing lit up (but my wheel has button LEDs)"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="ColorNotWorking_Click"/>
                    <Button Content="&#x2716;  My wheel has no button / color LEDs"
                            HorizontalAlignment="Stretch" Click="ColorNone_Click"/>
                </StackPanel>
                <StackPanel x:Name="panelColorCount" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock Text="How many lit up?" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cboColorCount" SelectedIndex="0">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="8"/>
                        <ComboBoxItem Content="9"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="11"/>
                        <ComboBoxItem Content="12"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock x:Name="txtColorResult" HorizontalAlignment="Center"
                           Margin="0,12,0,0" FontWeight="Bold" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 5: Color format probe -->
            <StackPanel x:Name="stepColorFormat" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                    A specific shade of green has been sent to your color LEDs.
                    The LEDs should still be green from the previous step.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,20" FontWeight="Bold">
                    What do you see?
                </TextBlock>
                <StackPanel HorizontalAlignment="Center">
                    <Button Content="&#x1F7E2;  The LEDs are still green (bright or dim)"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="ColorSame_Click"/>
                    <Button Content="&#x26AB;  The LEDs are OFF or a completely wrong color"
                            HorizontalAlignment="Stretch" Click="ColorDark_Click"/>
                </StackPanel>
                <TextBlock x:Name="txtColorFormatResult" HorizontalAlignment="Center"
                           Margin="0,16,0,0" FontWeight="Bold" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 6: Mono LED probe -->
            <StackPanel x:Name="stepMonoLeds" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16">
                    All color LEDs have been turned off and the intensity channel
                    is now blinking at full brightness.  Some wheels have additional
                    single-color (monochrome) LEDs — often behind encoder knobs —
                    that only respond to the intensity channel.
                    Look for any LEDs that are visibly blinking on and off right now.
                </TextBlock>
                <StackPanel HorizontalAlignment="Center">
                    <Button Content="&#x2714;  I see LEDs blinking — let me count them"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="MonoSome_Click"/>
                    <Button Content="&#x2716;  Nothing is blinking"
                            HorizontalAlignment="Stretch" Click="MonoNone_Click"/>
                </StackPanel>
                <StackPanel x:Name="panelMonoCount" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock Text="How many new LEDs?" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cboMonoCount" SelectedIndex="0">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="8"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock x:Name="txtMonoResult" HorizontalAlignment="Center"
                           Margin="0,12,0,0" FontWeight="Bold" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 7: Input Mapping -->
            <StackPanel x:Name="stepInputMapping" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                    One LED is lit at a time — press the button or wiggle the
                    encoder back and forth next to the glowing LED.
                </TextBlock>
                <TextBlock x:Name="txtInputProgress" FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="#FFCC00" />

                <!-- Current LED indicator -->
                <Border Background="#FF333333" CornerRadius="6" Padding="12,10"
                        Margin="0,0,0,8" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="txtInputLedLabel" FontSize="15"
                                   FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="txtInputLedDetail" Foreground="#AAAAAA"
                                   FontSize="11" Margin="0,2,0,0"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Detected input display -->
                <TextBlock x:Name="txtDetectedInput" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"
                           Foreground="#44DD44" FontSize="14" />

                <!-- Encoder mode banner — shows the detected hardware mode -->
                <Border x:Name="panelEncoderModeBanner" Visibility="Collapsed"
                        Background="#FF2A2A3A" CornerRadius="4" Padding="10,6"
                        Margin="0,0,0,8" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtEncoderMode" TextWrapping="Wrap"
                               HorizontalAlignment="Center" FontSize="12"
                               Foreground="#FFCC00" />
                </Border>

                <!-- Relative encoder confirmation (auto-detected both directions) -->
                <StackPanel x:Name="panelRelativeCapture" Visibility="Collapsed"
                            HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock x:Name="txtRelativePrompt"
                               TextWrapping="Wrap" HorizontalAlignment="Center"
                               Margin="0,0,0,4" />
                    <TextBlock x:Name="txtRelativeStatus" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"
                               Foreground="#44DD44" FontSize="14" />
                    <Button x:Name="btnRelativeConfirm" Content="&#x2714;  Confirm"
                            HorizontalAlignment="Stretch"
                            Click="RelativeConfirm_Click" IsEnabled="False" />
                </StackPanel>

                <!-- Absolute encoder capture — collect all positions -->
                <StackPanel x:Name="panelAbsoluteCapture" Visibility="Collapsed"
                            HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock x:Name="txtAbsolutePrompt" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Margin="0,0,0,4" />
                    <TextBlock x:Name="txtAbsoluteCount" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"
                               Foreground="#44DD44" FontSize="14" />
                    <Button x:Name="btnAbsoluteDone" Content="&#x2714;  Done — all positions captured"
                            HorizontalAlignment="Stretch"
                            Click="AbsoluteDone_Click" IsEnabled="False" />
                </StackPanel>

                <!-- LED-level navigation (always visible during input mapping) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,12,0,0">
                    <Button x:Name="btnInputPrev" Content="&#x25C0; Prev"
                            Margin="0,0,8,0" Click="InputPrev_Click"
                            IsEnabled="False" />
                    <Button Content="&#x21BA; Reset"
                            Margin="0,0,8,0" Click="InputRetry_Click" />
                    <Button Content="Skip &#x25B6;"
                            Click="InputSkip_Click" />
                </StackPanel>
            </StackPanel>

            <!-- Step 8: Summary -->
            <Grid x:Name="stepSummary" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12">
                    Review the detected capabilities.  Click Save to write the profile.
                </TextBlock>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtSummary" TextWrapping="Wrap"
                               FontFamily="Consolas" FontSize="13" LineHeight="22" />
                </ScrollViewer>
            </Grid>

        </Grid>

        <!-- ── Navigation ──────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnBack" Content="&#x2190; Back"
                    Margin="0,0,8,0" Click="BtnBack_Click" IsEnabled="False"/>
            <Button x:Name="btnNext" Content="Next &#x2192;"
                    Margin="0,0,8,0" Click="BtnNext_Click"/>
            <Button x:Name="btnSave" Content="Save Profile"
                    Margin="0,0,8,0" Click="BtnSave_Click" Visibility="Collapsed"/>
            <Button x:Name="btnCancel" Content="Cancel"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
